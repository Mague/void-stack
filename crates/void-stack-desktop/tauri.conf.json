{
  "productName": "Void Stack",
  "version": "0.31.0",
  "identifier": "dev.void-stack.desktop",
  "build": {
    "frontendDist": "./frontend/dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Void Stack",
        "width": 1360,
        "height": 860,
        "resizable": true,
        "fullscreen": false,
        "minWidth": 1280,
        "minHeight": 800
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico",
      "icons/icon.png"
    ]
  }
}